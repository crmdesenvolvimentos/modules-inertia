{
    "name": "crmdesenvolvimentos/modules-inertia",
    "description": "Relationship Vue/InertiaJs with modular structure Laravel-Modules",
    "keywords": [
        "nwidart",
        "laravel-modules",
        "Vue",
        "InertiaJS",
        "laravel",
        "vite",
        "php"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Celio Martins",
            "email": "crmdesenvolvimentos@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1.0",
        "laravel/framework": "^10.0||^11.0||^12.0||^13.0",
        "nwidart/laravel-modules": "^10.0||^11.0||^12.0||^13.0",
        "inertiajs/inertia-laravel": "^2.0||^3.0"
    },
    "autoload": {
        "psr-4": {
            "Crmdesenvolvimentos\\ModulesInertia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Crmdesenvolvimentos\\ModulesInertia\\Tests\\": "tests/"
        }
    },
    "extra" :{
        "branch-alias": {
            "dev-master": "13.x-dev"
        },
        "laravel": {
            "providers": [
                "Crmdesenvolvimentos\\ModulesInertia\\ModulesInertiaServiceProvider"
            ]
        }
    },
    "prefer-stable": true
}
